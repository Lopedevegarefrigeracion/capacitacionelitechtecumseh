<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Capacitación Profesionales de la Refrigeración – Elitech × Tecumseh</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&family=Inter:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:   #0D2E5E;
      --blue:   #1A4A8A;
      --orange: #F47920;
      --white:  #FFFFFF;
      --light:  #F5F7FA;
      --text:   #1C1C2E;
      --muted:  #5A6780;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--white);
      color: var(--text);
      overflow-x: hidden;
    }

    /* ── HERO ── */
    .hero {
      background: var(--navy);
      position: relative;
      overflow: hidden;
      padding: 60px 24px 120px;
      text-align: center;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }

    .hero::after {
      content: '';
      position: absolute;
      bottom: -2px; left: -5%;
      width: 110%;
      height: 90px;
      background: var(--white);
      clip-path: polygon(0 60%, 100% 0%, 100% 100%, 0% 100%);
    }

    .hero-inner { position: relative; z-index: 1; max-width: 680px; margin: 0 auto; }

    .logos {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      margin-bottom: 40px;
    }

    .logo-badge {
      background: var(--white);
      border-radius: 12px;
      padding: 10px 24px;
      display: flex;
      align-items: center;
    }

    .logo-tecumseh {
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
      font-size: 20px;
      color: var(--navy);
      letter-spacing: 1px;
    }

    .logo-elitech {
      font-family: 'Montserrat', sans-serif;
      font-weight: 900;
      font-size: 22px;
      color: var(--orange);
      font-style: italic;
    }

    .logo-divider {
      width: 2px;
      height: 44px;
      background: var(--orange);
      border-radius: 2px;
    }

    .eyebrow {
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: rgba(255,255,255,.55);
      margin-bottom: 18px;
    }

    .hero h1 {
      font-family: 'Montserrat', sans-serif;
      font-weight: 900;
      font-size: clamp(30px, 6vw, 54px);
      line-height: 1.05;
      color: var(--white);
      text-transform: uppercase;
      margin-bottom: 28px;
    }

    .hero h1 span { color: var(--orange); }

    .location-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,.1);
      border: 1px solid rgba(255,255,255,.2);
      color: var(--white);
      border-radius: 100px;
      padding: 9px 22px;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .location-pill svg { fill: var(--orange); flex-shrink: 0; }

    /* ── PRODUCTS ── */
    .products {
      padding: 80px 24px 60px;
      background: var(--white);
      text-align: center;
    }

    .eyebrow-dark {
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 14px;
    }

    .section-title {
      font-family: 'Montserrat', sans-serif;
      font-weight: 900;
      font-size: clamp(22px, 4vw, 34px);
      color: var(--navy);
      text-transform: uppercase;
      margin-bottom: 48px;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 24px;
      max-width: 820px;
      margin: 0 auto;
    }

    .card {
      background: var(--navy);
      border-radius: 20px;
      padding: 40px 28px 36px;
      text-align: left;
      position: relative;
      overflow: hidden;
      transition: transform .2s, box-shadow .2s;
    }

    .card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(13,46,94,.2); }

    .card::before {
      content: '';
      position: absolute;
      top: 0; right: 0;
      width: 80px; height: 80px;
      background: var(--orange);
      border-radius: 0 20px 0 80px;
      opacity: .15;
    }

    .card-icon {
      width: 52px; height: 52px;
      background: var(--orange);
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 22px;
    }

    .card-icon svg { color: var(--white); }

    .card h3 {
      font-family: 'Montserrat', sans-serif;
      font-weight: 900;
      font-size: 17px;
      color: var(--white);
      text-transform: uppercase;
      line-height: 1.3;
    }

    /* ── DATE BAND ── */
    .date-band {
      background: var(--navy);
      display: flex;
      align-items: stretch;
      overflow: hidden;
    }

    .date-prox {
      background: var(--blue);
      color: var(--white);
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 2px;
      padding: 28px 36px;
      display: flex;
      align-items: center;
      flex: 1;
    }

    .date-number {
      background: var(--orange);
      color: var(--white);
      font-family: 'Montserrat', sans-serif;
      font-weight: 900;
      font-size: 72px;
      line-height: 1;
      padding: 20px 32px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .date-month {
      background: var(--orange);
      color: rgba(255,255,255,.9);
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 16px;
      text-transform: uppercase;
      letter-spacing: 2px;
      padding: 28px 36px 28px 4px;
      display: flex;
      align-items: flex-end;
    }

    @media (max-width: 500px) {
      .date-prox { padding: 20px; font-size: 12px; }
      .date-number { font-size: 52px; padding: 20px 20px; }
      .date-month { padding: 20px 20px 20px 0; font-size: 13px; }
    }

    /* ── REGISTER ── */
    .register {
      padding: 80px 24px;
      background: var(--light);
      text-align: center;
    }

    .form-wrap {
      max-width: 640px;
      margin: 0 auto;
      background: var(--white);
      border-radius: 24px;
      padding: 48px 40px;
      border: 1px solid #E2E8F0;
    }

    @media (max-width: 480px) { .form-wrap { padding: 32px 16px; } }

    .form-sub {
      font-size: 15px;
      color: var(--muted);
      margin-bottom: 32px;
      margin-top: 8px;
    }

    .btn-register {
      display: inline-block;
      padding: 18px 48px;
      background: var(--orange);
      color: var(--white);
      border-radius: 12px;
      font-family: 'Montserrat', sans-serif;
      font-weight: 800;
      font-size: 17px;
      text-transform: uppercase;
      letter-spacing: 1px;
      text-decoration: none;
      transition: background .2s, transform .15s;
    }

    .btn-register:hover { background: #D96A10; transform: translateY(-2px); }
    .btn-register:active { transform: translateY(0); }

    /* ── FOOTER ── */
    footer {
      background: var(--navy);
      padding: 36px 24px;
      text-align: center;
    }

    .footer-logo {
      font-family: 'Montserrat', sans-serif;
      font-weight: 900;
      font-size: 18px;
      color: var(--white);
      text-transform: uppercase;
      letter-spacing: 3px;
    }

    .footer-sub {
      font-size: 12px;
      color: rgba(255,255,255,.4);
      margin-top: 6px;
      letter-spacing: 2px;
      text-transform: uppercase;
    }
  </style>
</head>
<body>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">

    <div class="logos">
      <div class="logo-badge">
        <span class="logo-tecumseh">Tecumseh</span>
      </div>
      <div class="logo-divider"></div>
      <div class="logo-badge">
        <span class="logo-elitech">Elitech</span>
      </div>
    </div>

    <p class="eyebrow">Capacitación</p>

    <h1>Para <span>Profesionales</span><br>de la Refrigeración</h1>

    <div class="location-pill">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
      Capital Federal
    </div>

  </div>
</section>

<!-- PRODUCTS -->
<section class="products">
  <p class="eyebrow-dark">Temario</p>
  <h2 class="section-title">Contenido de la capacitación</h2>

  <div class="cards">

    <div class="card">
      <div class="card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
      </div>
      <h3>Controladores y Tableros<br>Digitales Elitech</h3>
    </div>

    <div class="card">
      <div class="card-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07M8.46 8.46a5 5 0 0 0 0 7.07"/>
        </svg>
      </div>
      <h3>Unidades Condensadoras<br>Tauri de Tecumseh</h3>
    </div>

  </div>
</section>

<!-- DATE BAND -->
<div class="date-band">
  <div class="date-prox">Próximamente<br>más información</div>
  <div class="date-number">06</div>
  <div class="date-month">de<br>agosto</div>
</div>

<!-- REGISTER -->
<section class="register" id="registro">
  <div class="form-wrap">
    <h2 class="section-title" style="margin-bottom:0">Registrate</h2>
    <p class="form-sub">Completá el formulario y te avisamos cuando haya más información</p>
    <a
      class="btn-register"
      href="https://docs.google.com/forms/d/e/1FAIpQLSetUCb2RPhvr6eHScMTln-ip2uoAG4Cdru5ZQKrczmaueZNtQ/viewform?usp=header"
      target="_blank"
      rel="noopener noreferrer"
    >Completar formulario →</a>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">Lope de Vega Refrigeración</div>
  <p class="footer-sub">Capital Federal · Buenos Aires</p>
</footer>



</body>
</html>
